# Copy this to .env for local testing, or set these as Environment Variables
# in your Render dashboard (Settings -> Environment).

PREFIX=.
OWNER_NAME=Mr Elephant
OWNER_NUMBER=263000000000
AUTO_READ=false

# Paste a session ID generated from the pairing website here to boot the
# bot already connected, with no pairing step needed on this deployment.
# Format: ELEPHANT-X MD~xxxxxxxxxxxxxxxxxxxxx
SESSION_ID=

# Optional — only needed for .ask and .chatbot AI replies.
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
